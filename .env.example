# Application
APP_ENV=local
APP_NAME=telegram-calendar-bot-helper
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Moscow

# Database and cache
DATABASE_URL=postgresql+asyncpg://bot_helper:bot_helper@postgres:5432/bot_helper
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=put-telegram-bot-token-here
TELEGRAM_WEBHOOK_SECRET=change-this-secret
ADMIN_TELEGRAM_IDS=123456789
ALLOWED_TELEGRAM_IDS=123456789,987654321

# MVP business settings
WORKDAYS=1,2,3,4,5
WORK_START_TIME=10:00
WORK_END_TIME=19:00
MEETING_DURATION_MINUTES=30
MIN_LEAD_TIME_MINUTES=120
BOOKING_HORIZON_DAYS=14
SLOT_BUFFER_MINUTES=0
PENDING_HOLD_MINUTES=15
PENDING_HOLD_STORAGE=redis
ENABLE_GOOGLE_MEET=true

# Google Calendar
# true = Service Account fallback without attendee email invite/Meet.
# false = OAuth user calendar mode with attendee email invite and Google Meet.
USE_GOOGLE_CALENDAR_SERVICE_ACCOUNT=false
GOOGLE_CALENDAR_ID=put-dedicated-calendar-id-here
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
# Alternative for hosting providers that inject JSON directly:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_FILE=./secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=./secrets/google-oauth-token.json
