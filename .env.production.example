# Production example. Copy to .env on the server and fill real secrets there.

# Application
APP_ENV=production
APP_NAME=telegram-calendar-bot-helper
APP_BASE_URL=https://calendar.treeboxfree.ru
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Moscow

# Server / TLS
# This domain already points to 132.243.23.203.
APP_DOMAIN=calendar.treeboxfree.ru
CADDY_EMAIL=admin@example.com

# Database and cache
POSTGRES_DB=bot_helper
POSTGRES_USER=bot_helper
POSTGRES_PASSWORD=change-strong-postgres-password
DATABASE_URL=postgresql+asyncpg://bot_helper:change-strong-postgres-password@postgres:5432/bot_helper
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=put-telegram-bot-token-here
TELEGRAM_WEBHOOK_SECRET=change-this-long-random-secret
ADMIN_TELEGRAM_IDS=123456789
ALLOWED_TELEGRAM_IDS=123456789,987654321

# MVP business settings
WORKDAYS=1,2,3,4,5
WORK_START_TIME=10:00
WORK_END_TIME=19:00
MEETING_DURATION_MINUTES=30
ALLOWED_MEETING_DURATIONS=15,30,45,60,90
MIN_LEAD_TIME_MINUTES=120
BOOKING_HORIZON_DAYS=14
SLOT_BUFFER_MINUTES=0
PENDING_HOLD_MINUTES=15
PENDING_HOLD_STORAGE=redis
ENABLE_GOOGLE_MEET=true

# Google Calendar
USE_GOOGLE_CALENDAR_SERVICE_ACCOUNT=false
GOOGLE_CALENDAR_ID=put-dedicated-calendar-id-here
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_FILE=/app/secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=/app/secrets/google-oauth-token.json
